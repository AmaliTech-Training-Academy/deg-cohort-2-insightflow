# ─────────────────────────────────────────────────────────────────────────────
# Prod deployment configuration
#
# This file is uploaded to EC2 at /tmp/deploy.env before each deploy.
# It holds NON-SECRET deploy-time settings only.
#
# App secrets (DB passwords, Django secret key, Redis URL, etc.) live in
# AWS Secrets Manager at insightflow-prod/* and are written to
# /opt/insightflow/.env during EC2 bootstrap (Terraform user_data).
# This file MUST NOT contain any secrets.
# ─────────────────────────────────────────────────────────────────────────────

DEPLOY_ENV=prod

# ── Application ───────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# Set to the real frontend URL in production (e.g. https://insightflow.example.com).
CORS_ALLOWED_ORIGINS=http://localhost:3001

# ── Paths (must match EC2 bootstrap) ─────────────────────────────────────────
APP_DIR=/opt/insightflow          # runtime dir — app .env and docker volumes
REPO_DIR=/opt/insightflow/repo    # git working tree

# ── Docker Compose ────────────────────────────────────────────────────────────
COMPOSE_PROJECT=insightflow       # sets container names and network prefix

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1

# ── Health checks ─────────────────────────────────────────────────────────────
CANARY_PORT=8081                  # temporary port for pre-flight canary
HEALTH_CHECK_PATH=/api-docs/      # must return HTTP 200
HEALTH_CHECK_RETRIES=36           # 36 × 5s = 3-minute canary window (prod gets more time)
HEALTH_CHECK_INTERVAL=5           # seconds between retries

# ── Image retention ───────────────────────────────────────────────────────────
# Prod keeps images longer — useful for forensic rollback without a rebuild.
IMAGE_PRUNE_KEEP_DAYS=14

# ── Deployment timeouts ───────────────────────────────────────────────────────
DEPLOY_TIMEOUT=600                # ssm-wait.sh max wait in seconds
