# ─────────────────────────────────────────────────────────────────────────────
# Prod deployment configuration — ECS + ECR
#
# Sourced by the GitHub Actions runner (not uploaded to any server).
# Contains NON-SECRET, environment-specific deploy settings only.
#
# App secrets live in AWS Secrets Manager at insightflow-prod/* and are
# injected into ECS tasks via the task-definition secrets: block, which
# Terraform manages. Never put secrets in this file.
# ─────────────────────────────────────────────────────────────────────────────

DEPLOY_ENV=prod
AWS_REGION=eu-west-1

# ── ECR — repository names (account + region prefix added at runtime) ─────────
ECR_BACKEND_REPO=insightflow/backend
ECR_FRONTEND_REPO=insightflow/frontend
ECR_ETL_REPO=insightflow/etl

# ── ECS — cluster and service names (must match Terraform outputs) ────────────
ECS_CLUSTER=insightflow-prod

ECS_BACKEND_SERVICE=insightflow-prod-backend
ECS_FRONTEND_SERVICE=insightflow-prod-frontend

# Task definition family names (used to fetch current revision from AWS)
ECS_BACKEND_TASK_FAMILY=insightflow-prod-backend
ECS_FRONTEND_TASK_FAMILY=insightflow-prod-frontend
ECS_ETL_TASK_FAMILY=insightflow-prod-etl

# Container names inside the task definitions
ECS_BACKEND_CONTAINER=backend
ECS_FRONTEND_CONTAINER=frontend
ECS_ETL_CONTAINER=etl

# ── ECS deployment behaviour ──────────────────────────────────────────────────
# Rolling update (default). To enable Blue/Green via CodeDeploy, set
# ECS_DEPLOYMENT_CONTROLLER=CODE_DEPLOY in Terraform and supply the
# CodeDeploy appspec path in the workflow deploy step.
ECS_DEPLOYMENT_MIN_HEALTHY=100
ECS_DEPLOYMENT_MAX_PERCENT=200

# Prod waits longer for service stability (large images, slower startup).
ECS_STABILITY_TIMEOUT=600

# ── CodeDeploy Blue/Green (prod only, requires Terraform CodeDeploy setup) ────
# Set these when the ECS service uses CODE_DEPLOY controller.
# Leave empty to use standard rolling update.
CODEDEPLOY_APP=insightflow-prod-backend-app
CODEDEPLOY_DEPLOYMENT_GROUP=insightflow-prod-backend-dg
CODEDEPLOY_APPSPEC=devops/ecs/appspec-backend.json

# ── ALB smoke test ────────────────────────────────────────────────────────────
SMOKE_TEST_PATH=/api-docs/     # endpoint that must return HTTP 200
SMOKE_TEST_RETRIES=24          # 24 × 10s = 4-minute window (prod has longer startup)
SMOKE_TEST_INTERVAL=10
