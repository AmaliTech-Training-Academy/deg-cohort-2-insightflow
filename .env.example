# Copy this file to .env and fill in your local values.
# Never commit .env to git.

# Django
DJANGO_SECRET_KEY=secret-key-for-development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,insightflow-backend
SECURE_SSL_REDIRECT=False

# Application database (local)
DB_HOST=insightflow-dev-app-db.cf6io6y406u0.eu-west-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=insightflow_app
DB_USER=insightflow
DB_PASSWORD=TestPAssword1234!

# Data warehouse (postgres-warehouse, port 5433)
WAREHOUSE_HOST=localhost
WAREHOUSE_PORT=5433
WAREHOUSE_NAME=insightflow_warehouse
WAREHOUSE_USER=postgres
WAREHOUSE_PASSWORD=postgres

# External source API

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ETL
ETL_BATCH_SIZE=1000
ONLINE_ORDERS_API_URL=https://ext-amali.vercel.app
EXTERNAL_API_BASE_URL=
REDIS_URL=redis://localhost:6379/0
