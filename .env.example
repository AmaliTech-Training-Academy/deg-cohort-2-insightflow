# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── OLTP source database (AWS RDS — insightflow_app) ─────────────────────────
# Used by: backend Django app AND the ETL extract step
DB_HOST=insightflow-dev-app-db.cf6io6y406u0.eu-west-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=insightflow_app
DB_USER=insightflow
DB_PASSWORD=<your-db-password>

# ── OLTP source database — data-engineering env var names ────────────────────
# Used by: data-engineering/config.py (ETL pipeline)
RDS_SOURCE_HOST=insightflow-dev-app-db.cf6io6y406u0.eu-west-1.rds.amazonaws.com
RDS_SOURCE_PORT=5432
RDS_SOURCE_DB_NAME=insightflow_app
RDS_SOURCE_USER=insightflow
RDS_SOURCE_PASSWORD=TestPAssword1234!

# ── OLAP warehouse database (AWS RDS — insightflow_warehouse) ────────────────
# Used by: data-engineering/config.py (ETL pipeline load step)
RDS_WAREHOUSE_HOST=insightflow-dev-warehouse-db.cf6io6y406u0.eu-west-1.rds.amazonaws.com
RDS_WAREHOUSE_PORT=5432
RDS_WAREHOUSE_DB_NAME=insightflow_warehouse
RDS_WAREHOUSE_USER=insightflow_wh
RDS_WAREHOUSE_PASSWORD=TestPAssword1234!

# ── ETL ───────────────────────────────────────────────────────────────────────
ETL_BATCH_SIZE=1000
