{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*":                          ["../../../frontend/src/*"],
      "vitest":                       ["../../../frontend/node_modules/vitest/dist/index.d.ts"],
      "vitest/*":                     ["../../../frontend/node_modules/vitest/*"],
      "@testing-library/react":       ["../../../frontend/node_modules/@testing-library/react"],
      "@testing-library/user-event":  ["../../../frontend/node_modules/@testing-library/user-event"],
      "@testing-library/jest-dom":    ["../../../frontend/node_modules/@testing-library/jest-dom"],
      "@tanstack/react-query":        ["../../../frontend/node_modules/@tanstack/react-query"],
      "react":                        ["../../../frontend/node_modules/@types/react"],
      "react-dom":                    ["../../../frontend/node_modules/@types/react-dom"],
      "next":                         ["../../../frontend/node_modules/next"],
      "next/*":                       ["../../../frontend/node_modules/next/*"],
      "next-themes":                  ["../../../frontend/node_modules/next-themes"]
    },
    "typeRoots": [
      "../../../frontend/node_modules/@types",
      "../../../frontend/node_modules"
    ],
    "types": ["@testing-library/jest-dom", "vitest/globals"]
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx"]
}
